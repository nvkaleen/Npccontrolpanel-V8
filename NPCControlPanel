local function allNPCRoots()
    local list = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local hrp = d.Parent:FindFirstChild("HumanoidRootPart")
            if hrp then table.insert(list, {hum=d, hrp=hrp, model=d.Parent}) end
        end
    end
    return list
end

local function allNPCRootsInRange(range)
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return {} end
    local myPos = myHRP.Position; local list = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local hrp = d.Parent:FindFirstChild("HumanoidRootPart")
            if hrp then local ok, dist = pcall(function() return (hrp.Position - myPos).Magnitude end)
                if ok and dist <= range then table.insert(list, {hum=d, hrp=hrp, model=d.Parent}) end end
        end
    end
    return list
end

