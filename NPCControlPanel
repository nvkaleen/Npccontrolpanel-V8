local function reset()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        workspace.CurrentCamera.CameraSubject = player.Character:FindFirstChildOfClass("Humanoid")
    end
end

createAction("Kill NPCs Loop", Color3.fromRGB(46, 139, 87), function()
    states.killNPCs = not states.killNPCs
    if states.killNPCs then
        task.spawn(function()
            local ep = loopEpoch
            while states.killNPCs and ep == loopEpoch do
                for _, d in pairs(workspace:GetDescendants()) do
                    if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then d.Health = 0 end
                end
                task.wait(0.5)
            end
        end)
    end
end)

createAction("Push NPCs Mode", Color3.fromRGB(70, 130, 180), function()
    states.pushNPCs = not states.pushNPCs
    task.spawn(function()
        local ep = loopEpoch
        while states.pushNPCs and ep == loopEpoch do
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, d in pairs(workspace:GetDescendants()) do
                    if d:IsA("Humanoid") and d.Parent ~= player.Character and not Players:GetPlayerFromCharacter(d.Parent) then
                        local t = d.Parent:FindFirstChild("HumanoidRootPart")
                        if t and (t.Position - hrp.Position).Magnitude <= pushRange then
                            t.Velocity = (t.Position - hrp.Position).Unit * pushStrength + Vector3.new(0, 20, 0)
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end)

createAction("Fling All NPCs", Color3.fromRGB(123, 104, 238), function()
    for _, d in pairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local r = d.Parent:FindFirstChild("HumanoidRootPart")
            if r then r.Velocity = Vector3.new(math.random(-1,1), 1, math.random(-1,1)).Unit * flingStrength end
        end
    end
end)

createAction("Bring All NPCs", Color3.fromRGB(0, 139, 139), function()
