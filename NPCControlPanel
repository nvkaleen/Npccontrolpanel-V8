local function bringNPCToPos(e, targetCFrame, displayName)
    local oWS, oJP, oJH = 16, 50, 7.2
    pcall(function() e.hrp.Anchored=false; e.hrp.CFrame=targetCFrame; oWS,oJP,oJH=nukeNPCMovement(e.model,e.hrp,e.hum) end)
    if not anchoredNPCs[e.model] then
        anchoredNPCs[e.model] = {hrp=e.hrp, hum=e.hum, name=displayName or e.model.Name, origWS=oWS, origJP=oJP, origJH=oJH}
    end
end

local function isNPCAtPos(hrp, targetCFrame, threshold)
    local ok, dist = pcall(function() return (hrp.Position - targetCFrame.Position).Magnitude end)
    if ok then return dist <= (threshold or 2) end; return false
end

local function unanchorNPC(model)
    local data = anchoredNPCs[model]; if not data then return end
    pcall(function() data.hrp.Anchored=false; data.hum.PlatformStand=false; data.hum.WalkSpeed=data.origWS or 16; data.hum.JumpPower=data.origJP or 50; data.hum.JumpHeight=data.origJH or 7.2; pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end)
    anchoredNPCs[model] = nil
end
local function unanchorAllNPCs() for model,_ in pairs(anchoredNPCs) do unanchorNPC(model) end; anchoredNPCs={} end

local function letNPCMove(model, data)
    pcall(function()
        for _, part in ipairs(model:GetDescendants()) do if part:IsA("BasePart") then part.Anchored = false end end
        data.hum.PlatformStand = false; data.hum.WalkSpeed = data.origWS or 16; data.hum.JumpPower = data.origJP or 50; data.hum.JumpHeight = data.origJH or 7.2
        for _, j in ipairs(model:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled = true end end
        for _, obj in ipairs(model:GetDescendants()) do if obj:IsA("BallSocketConstraint") then pcall(function() obj:Destroy() end) end end
        for _, j in ipairs(model:GetDescendants()) do if j:IsA("Motor6D") then pcall(function() j:SetAttribute("_ragdolled", nil) end) end end
        pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1); pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        if data.hrp then data.hrp.Velocity = Vector3.new(0, 5, 0) end
    end)
end

local function letAllNPCsMove()
    local count = 0
    for model, data in pairs(anchoredNPCs) do
        local exists = pcall(function() local _ = data.hrp.Position end)
        if exists and model.Parent then letNPCMove(model, data); count = count + 1 end
    end
    anchoredNPCs = {}; return count
end

-- Freeze/Unfreeze NPC
local function freezeNPC(model)
    local hrp = model:FindFirstChild("HumanoidRootPart")
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hrp then
        pcall(function() hrp.Anchored = true; hrp.Velocity = Vector3.new(0,0,0) end)
        pcall(function() hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
    end
    if hum then pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0 end) end
end

local function unfreezeNPC(model)
    local hrp = model:FindFirstChild("HumanoidRootPart")
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored = false end) end
    if hum then pcall(function() hum.WalkSpeed = 16; hum.JumpPower = 50 end) end
end

local function isNPCFrozen(model)
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if hrp then local ok, v = pcall(function() return hrp.Anchored end); if ok then return v end end
    return false
end

-- NPC Follow Player loop
local function startFollowLoop()
    if followLoopActive then return end
    followLoopActive = true
    task.spawn(function()
        local ep = loopEpoch
        while followLoopActive and ep == loopEpoch do
            local mH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if mH then
                for model, _ in pairs(followingNPCs) do
                    pcall(function()
                        if model.Parent then
                            local hrp = model:FindFirstChild("HumanoidRootPart")
                            local hum = model:FindFirstChildOfClass("Humanoid")
                            if hrp and hum then
                                local dir = (mH.Position - hrp.Position)
                                local dist = dir.Magnitude
                                if dist > 5 then
                                    hrp.CFrame = hrp.CFrame + dir.Unit * math.min(hum.WalkSpeed * 0.03, dist - 3)
                                    -- Face the player
                                    hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(mH.Position.X, hrp.Position.Y, mH.Position.Z))
                                end
                            end
                        else
                            followingNPCs[model] = nil
                        end
                    end)
                end
            end
            task.wait(0.03)
        end
    end)
end

local function applySpeed(speed)
