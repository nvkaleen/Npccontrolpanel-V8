local function ragdollNPC(model)
    local hum = model:FindFirstChildOfClass("Humanoid"); if not hum then return end
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Ragdoll) end)
    pcall(function() hum.PlatformStand = true end)
    pcall(function() for _, j in ipairs(model:GetDescendants()) do
        if j:IsA("Motor6D") and not j:GetAttribute("_ragdolled") then j:SetAttribute("_ragdolled", true)
            local a0=Instance.new("Attachment"); a0.CFrame=j.C0; a0.Parent=j.Part0
            local a1=Instance.new("Attachment"); a1.CFrame=j.C1; a1.Parent=j.Part1
            local b=Instance.new("BallSocketConstraint"); b.Attachment0=a0; b.Attachment1=a1; b.LimitsEnabled=true; b.TwistLimitsEnabled=true; b.UpperAngle=45; b.TwistLowerAngle=-45; b.TwistUpperAngle=45; b.Parent=j.Parent; j.Enabled=false
        end end end)
    local hrp = model:FindFirstChild("HumanoidRootPart"); if hrp then hrp.Velocity = hrp.Velocity + Vector3.new(0,30,0) end
end

local function nukeNPCMovement(model, hrp, hum)
    pcall(function() for _, obj in ipairs(model:GetDescendants()) do
        if obj:IsA("BodyVelocity") or obj:IsA("BodyPosition") or obj:IsA("BodyGyro") or obj:IsA("BodyForce") or obj:IsA("BodyThrust") or obj:IsA("BodyAngularVelocity") or obj:IsA("LinearVelocity") or obj:IsA("AlignPosition") or obj:IsA("AlignOrientation") or obj:IsA("VectorForce") or obj:IsA("LineForce") or obj:IsA("Torque") then obj:Destroy() end end end)
    pcall(function() for _, obj in ipairs(model:GetDescendants()) do
        if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then pcall(function() obj.Disabled=true end); pcall(function() obj:Destroy() end) end end end)
    pcall(function() for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then pcall(function() part.Velocity=Vector3.new(0,0,0) end); pcall(function() part.AssemblyLinearVelocity=Vector3.new(0,0,0) end); pcall(function() part.AssemblyAngularVelocity=Vector3.new(0,0,0) end) end end end)
    local oWS,oJP,oJH = 16,50,7.2
    pcall(function() oWS=hum.WalkSpeed end); pcall(function() oJP=hum.JumpPower end); pcall(function() oJH=hum.JumpHeight end)
    pcall(function() hum.WalkSpeed=0; hum.JumpPower=0; hum.JumpHeight=0 end)
    pcall(function() hum.PlatformStand=true end); pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hrp.Anchored=true end)
    pcall(function() for _, obj in ipairs(hrp:GetChildren()) do
        if obj:IsA("Weld") or obj:IsA("WeldConstraint") then local p0=obj:IsA("Weld") and obj.Part0 or nil; local p1=obj:IsA("Weld") and obj.Part1 or nil
            if p0 and not p0:IsDescendantOf(model) then obj:Destroy() elseif p1 and not p1:IsDescendantOf(model) then obj:Destroy() end end end end)
    return oWS, oJP, oJH
end

