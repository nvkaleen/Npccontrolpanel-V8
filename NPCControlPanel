local connections = {}
local function track(conn)
    table.insert(connections, conn)
    return conn
end

local states = {
    killNPCs = false, pushNPCs = false, nk = false,
    freeze = false, killClick = false, fling = false,
    objDel = false, autoFling = false, viewNPC = false
}
local anchorActive = false
local loopEpoch = 0

local pushStrength = 150
local pushRange = 15
local flingStrength = 300
local pushRangeVisual = nil

local function cleanup()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    anchorActive = false
    
    -- Restore Camera
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if hum then workspace.CurrentCamera.CameraSubject = hum end

    for _, conn in ipairs(connections) do if conn.Connected then conn:Disconnect() end end
    table.clear(connections)
    if pushRangeVisual then pushRangeVisual:Destroy() pushRangeVisual = nil end
    
    local old = playerGui:FindFirstChild("NPCControlGUICeraulean")
    if old then old:Destroy() end
end

_G[CONTROL_KEY] = cleanup

