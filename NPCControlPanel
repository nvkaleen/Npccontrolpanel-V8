local function makeSlider(cfg)
    local cn=Instance.new("Frame"); cn.Size=UDim2.new(1,-16,0,52); cn.Position=UDim2.new(0,8,0,cfg.yOffset)
    cn.BackgroundTransparency=1; cn.ZIndex=60; cn.Parent=cfg.parent
    local lb=Instance.new("TextLabel"); lb.Size=UDim2.new(1,0,0,18); lb.BackgroundTransparency=1; lb.Font=Enum.Font.Gotham
    lb.TextColor3=Color3.fromRGB(190,190,220); lb.TextSize=11; lb.TextXAlignment=Enum.TextXAlignment.Left; lb.ZIndex=61; lb.Parent=cn
    local tb=Instance.new("Frame"); tb.Size=UDim2.new(1,-16,0,7); tb.Position=UDim2.new(0,8,0,28)
    tb.BackgroundColor3=Color3.fromRGB(48,48,68); tb.BorderSizePixel=0; tb.ZIndex=61; tb.Parent=cn; Instance.new("UICorner",tb).CornerRadius=UDim.new(1,0)
    local fl=Instance.new("Frame"); fl.Size=UDim2.new(0,0,1,0); fl.BackgroundColor3=Color3.fromRGB(0,150,240)
    fl.BorderSizePixel=0; fl.ZIndex=62; fl.Parent=tb; Instance.new("UICorner",fl).CornerRadius=UDim.new(1,0)
    local kn=Instance.new("Frame"); kn.Size=UDim2.new(0,16,0,16); kn.AnchorPoint=Vector2.new(0.5,0.5)
    kn.BackgroundColor3=Color3.fromRGB(0,190,255); kn.BorderSizePixel=0; kn.ZIndex=63; kn.Parent=tb; Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)
    local function ap(p) p=math.clamp(p,0,1); local v=math.floor(cfg.min+p*(cfg.max-cfg.min)); fl.Size=UDim2.new(p,0,1,0); kn.Position=UDim2.new(p,0,0.5,0); lb.Text=cfg.label.."  —  "..v; cfg.onChange(v) end
    ap((cfg.default-cfg.min)/(cfg.max-cfg.min))
    local sl=false
    local function um() ap((UserInputService:GetMouseLocation().X-tb.AbsolutePosition.X)/tb.AbsoluteSize.X) end
    local function bs(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=true; um() end end
    track(kn.InputBegan:Connect(bs)); track(tb.InputBegan:Connect(bs))
    track(UserInputService.InputChanged:Connect(function(i) if sl and i.UserInputType==Enum.UserInputType.MouseMovement then um() end end))
    track(UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=false end end))
end

