local function ragdollNPC(m) local hum=m:FindFirstChildOfClass("Humanoid"); if not hum then return end
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end); pcall(function() hum.PlatformStand=true end)
    pcall(function() for _,j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") and not j:GetAttribute("_r") then j:SetAttribute("_r",true)
        local a0=Instance.new("Attachment"); a0.CFrame=j.C0; a0.Parent=j.Part0; local a1=Instance.new("Attachment"); a1.CFrame=j.C1; a1.Parent=j.Part1
