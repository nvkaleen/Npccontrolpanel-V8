-- [[ UTILITY FUNCTIONS ]] --
local function makeDraggable(dragBar, frame)  
    local dragging, dragStart, startPos  
    track(dragBar.InputBegan:Connect(function(input)  
        if input.UserInputType == Enum.UserInputType.MouseButton1 then  
            dragging = true  
            dragStart = UserInputService:GetMouseLocation()
            startPos = frame.Position  
        end  
    end))  
    track(UserInputService.InputChanged:Connect(function(input)  
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then  
            local mPos = UserInputService:GetMouseLocation()
            local delta = mPos - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)  
        end  
    end))  
    track(UserInputService.InputEnded:Connect(function(input)  
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end  
    end))  
end  
  
makeDraggable(topBar, mainFrame)  
makeDraggable(setTop, settingsFrame)

local function createSettingSlider(parent, yPos, labelText, defaultValue, minVal, maxVal, onChanged, onStateChange)  
    local section = Instance.new("Frame")  
    section.Size = UDim2.new(1, -30, 0, 75)  
    section.Position = UDim2.new(0, 15, 0, yPos)  
    section.BackgroundTransparency = 1  
    section.ZIndex = 21  
    section.Parent = parent  
  
    local label = Instance.new("TextLabel")  
    label.Size = UDim2.new(1, -60, 0, 18)  
    label.BackgroundTransparency = 1  
    label.Text = labelText
    label.Font = Enum.Font.Gotham
    label.TextSize = 13  
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 22  
    label.Parent = section  
  
    local sliderTrack = Instance.new("Frame")  
    sliderTrack.Size = UDim2.new(1, -65, 0, 8)  
    sliderTrack.Position = UDim2.new(0, 0, 0, 28)  
    sliderTrack.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
    sliderTrack.Active = true
    sliderTrack.ZIndex = 22  
    sliderTrack.Parent = section  
    Instance.new("UICorner", sliderTrack)
  
    local fill = Instance.new("Frame")  
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    fill.ZIndex = 22  
    fill.Parent = sliderTrack  
    Instance.new("UICorner", fill)
  
    local knob = Instance.new("Frame")  
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    knob.ZIndex = 23  
    knob.Parent = sliderTrack  
    Instance.new("UICorner", knob)
  
    local valueBtn = Instance.new("TextButton")  
    valueBtn.Size = UDim2.new(0, 55, 0, 28)
    valueBtn.Position = UDim2.new(1, -55, 0, 22)
    valueBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)  
    valueBtn.Text = tostring(defaultValue)
    valueBtn.Font = Enum.Font.GothamBold
    valueBtn.TextSize = 14
    valueBtn.TextColor3 = Color3.new(1, 1, 1)
    valueBtn.ZIndex = 22  
    valueBtn.Parent = section  
    Instance.new("UICorner", valueBtn)
  
    local isDragging = false  
  
    local function updateSlider(value)  
        local currentValue = math.clamp(math.floor(value or 0), minVal, maxVal)  
        local alpha = (currentValue - minVal) / (maxVal - minVal)  
        knob.Position = UDim2.new(alpha, 0, 0.5, 0)  
        fill.Size = UDim2.new(alpha, 0, 1, 0)  
        valueBtn.Text = tostring(currentValue)  
        onChanged(currentValue)  
    end  
  
    track(sliderTrack.InputBegan:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            isDragging = true 
            if onStateChange then onStateChange(true) end 
        end 
    end))  

    track(RunService.RenderStepped:Connect(function()  
        if isDragging then  
            if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then 
                isDragging = false 
                if onStateChange then onStateChange(false) end 
                return 
            end  
            local mPos = UserInputService:GetMouseLocation()
            local alpha = math.clamp((mPos.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
            updateSlider(minVal + (alpha * (maxVal - minVal)))
        end  
    end))  
  
    track(valueBtn.MouseButton1Click:Connect(function()  
        if onStateChange then onStateChange(true) end  
        local box = Instance.new("TextBox")  
        box.Size, box.Position, box.BackgroundColor3 = valueBtn.Size, valueBtn.Position, Color3.fromRGB(30, 30, 30)  
        box.Text, box.Font, box.TextSize, box.TextColor3, box.ZIndex, box.Parent = valueBtn.Text, valueBtn.Font, valueBtn.TextSize, Color3.new(1,1,1), 25, section  
        Instance.new("UICorner", box)  
        box:CaptureFocus()  
        box:GetPropertyChangedSignal("Text"):Connect(function() 
            local n = tonumber(box.Text) 
            if n then updateSlider(n) end 
        end)
        box.FocusLost:Connect(function() box:Destroy() if onStateChange then onStateChange(false) end end)  
    end))  
    updateSlider(defaultValue)  
end  
  
