-- Bring All (with filter)
track(buttons["Bring All NPCs"].MouseButton1Click:Connect(function()
    local char  = player.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    local npcs = allNPCRoots()
    local filtered = {}

    for _, e in ipairs(npcs) do
        local key = getNPCKey(e.model)
        -- If no filter entries exist, bring all. Otherwise check filter.
        local shouldBring = true
        if next(bringFilter) ~= nil then
            if bringFilter[key] == false then
                shouldBring = false
            end
        end
        if shouldBring then
            table.insert(filtered, e)
        end
    end

    for i, e in ipairs(filtered) do
        local angle  = (i / math.max(1, #filtered)) * math.pi * 2
        local offset = CFrame.new(math.cos(angle) * 4, 0, math.sin(angle) * 4)
        e.hrp.CFrame   = myHRP.CFrame * offset
        e.hrp.Velocity  = Vector3.new(0, 0, 0)
    end
end))

