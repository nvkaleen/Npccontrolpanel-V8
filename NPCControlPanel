-- EXPLODE NPC
local function explodeNPC(model)
    local hrp=model:FindFirstChild("HumanoidRootPart")
    local hum=model:FindFirstChildOfClass("Humanoid")
    if hrp then
        pcall(function()
            local exp=Instance.new("Explosion")
            exp.Position=hrp.Position
            exp.BlastRadius=10
            exp.BlastPressure=500000
            exp.DestroyJointRadiusPercent=0
            exp.Parent=workspace
            -- Particles
            local att=Instance.new("Attachment"); att.Parent=hrp
            local emit=Instance.new("ParticleEmitter"); emit.Parent=att
            emit.Color=ColorSequence.new(Color3.fromRGB(255,100,0),Color3.fromRGB(255,255,0))
            emit.Size=NumberSequence.new(2,0)
            emit.Lifetime=NumberRange.new(0.3,0.8)
            emit.Speed=NumberRange.new(10,30)
            emit.Rate=200; emit.SpreadAngle=Vector2.new(180,180)
            task.delay(0.5,function() emit.Enabled=false; task.delay(1,function() pcall(function() att:Destroy() end) end) end)
        end)
    end
    if hum then pcall(function() hum.Health=0 end) end
end

-- ORBIT LOOP
local function startOrbitLoop()
    task.spawn(function()
        local ep=loopEpoch
        local angle=0
        while S.orbitLoop and ep==loopEpoch do
            local myH=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if myH then
                local count=#orbitNPCs
                for i,model in ipairs(orbitNPCs) do
                    pcall(function()
                        if not model.Parent then table.remove(orbitNPCs,i); return end
                        local hrp=model:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local a=angle+((i-1)/math.max(1,count))*math.pi*2
                            local targetPos=myH.Position+Vector3.new(math.cos(a)*orbitRadius,0,math.sin(a)*orbitRadius)
                            hrp.Anchored=false
                            hrp.CFrame=CFrame.new(targetPos,myH.Position)
                            hrp.Velocity=Vector3.new(0,0,0)
                        end
                    end)
                end
            end
            angle=angle+orbitSpeed*0.03
            task.wait(0.03)
        end
    end)
end

-- PLAY SOUND FROM NPC
local function playSoundOnNPC(model)
    pcall(function()
        local hrp=model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head")
        if not hrp then return end
        -- Remove old sounds we added
        for _,s in ipairs(hrp:GetChildren()) do if s:IsA("Sound") and s.Name=="NPCPanelSound" then s:Destroy() end end
        local sound=Instance.new("Sound")
        sound.Name="NPCPanelSound"
        sound.SoundId="rbxassetid://5153734236" -- default scream sound
        sound.Volume=1
        sound.Parent=hrp
        sound:Play()
        task.delay(3,function() pcall(function() sound:Destroy() end) end)
    end)
end

