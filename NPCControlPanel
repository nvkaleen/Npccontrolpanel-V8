local function cleanup()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    for _, c in ipairs(connections) do
        if typeof(c) == "RBXScriptConnection" and c.Connected then
            c:Disconnect()
        end
    end
    connections = {}
    local function removeFrom(p)
        if p then
            local old = p:FindFirstChild("NPCControlGUI_v6")
            if old then old:Destroy() end
        end
    end
    removeFrom(uiParent)
    pcall(removeFrom, player:FindFirstChild("PlayerGui"))
    pcall(removeFrom, game:GetService("CoreGui"))
end
_G[CONTROL_KEY] = cleanup

local function resetCamera()
    viewingNPC = false
    viewedHumanoid = nil
