-- [[ SLIDER LOGIC ]]
local function createSlider(yPos, labelText, default, min, max, callback, onVisual)
    local sFrame = Instance.new("Frame")
    sFrame.Size = UDim2.new(1, -20, 0, 60)
    sFrame.Position = UDim2.new(0, 10, 0, yPos)
    sFrame.BackgroundTransparency = 1
    sFrame.ZIndex = 110
    sFrame.Parent = settingsFrame

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Text = labelText.." ["..default.."]"
    lbl.TextColor3 = Color3.new(0.9,0.9,0.9)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.BackgroundTransparency = 1
    lbl.ZIndex = 111
    lbl.Parent = sFrame

    local tLine = Instance.new("Frame")
    tLine.Size = UDim2.new(1, -10, 0, 6)
    tLine.Position = UDim2.new(0, 5, 0, 30)
    tLine.BackgroundColor3 = Color3.fromRGB(60,60,60)
    tLine.ZIndex = 111
    tLine.Parent = sFrame
    
    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new((default-min)/(max-min), -8, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    knob.Text = ""
    knob.ZIndex = 112
    knob.Parent = tLine
    Instance.new("UICorner", knob)

    local drag = false
    local function update()
        local percent = math.clamp((UserInputService:GetMouseLocation().X - tLine.AbsolutePosition.X) / tLine.AbsoluteSize.X, 0, 1)
        knob.Position = UDim2.new(percent, -8, 0.5, -8)
        local val = math.floor(min + (percent * (max - min)))
        lbl.Text = labelText.." ["..val.."]"
        callback(val)
    end

    track(knob.MouseButton1Down:Connect(function() drag = true if onVisual then onVisual(true) end end))
    track(UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then if drag and onVisual then onVisual(false) end drag = false end end))
    track(RunService.RenderStepped:Connect(function() if drag then update() end end))
end

