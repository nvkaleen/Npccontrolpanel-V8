    pushRangeVisual.Transparency = a and 0.9 or 1
    if a then
        track(RunService.RenderStepped:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then 
                pushRangeVisual.CFrame = hrp.CFrame 
                pushRangeVisual.Size = Vector3.new(pushRange*2, pushRange*2, pushRange*2)
            end
        end))
    end
end)

