                if myHRP then
                    for _, e in ipairs(allNPCRoots()) do
                        local dist = (e.hrp.Position - myHRP.Position).Magnitude
                        if dist <= pushRange then
                            local dir = (e.hrp.Position - myHRP.Position).Unit
                            e.hrp.Velocity = dir * pushStrength + Vector3.new(0, 20, 0)
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
end))

