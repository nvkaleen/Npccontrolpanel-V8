        local en=true; if cfg.filterTable[ky]~=nil then en=cfg.filterTable[ky] end
        local tb2=Instance.new("TextButton"); tb2.Size=UDim2.new(0,58,0,22); tb2.Position=UDim2.new(1,-62,0.5,-11); tb2.BackgroundColor3=en and Color3.fromRGB(38,130,75) or Color3.fromRGB(95,32,32); tb2.Text=en and ("✓ "..cfg.onLabel) or ("✗ "..cfg.offLabel); tb2.Font=Enum.Font.GothamBold; tb2.TextColor3=Color3.new(1,1,1); tb2.TextSize=9; tb2.ZIndex=84; tb2.Parent=rw; Instance.new("UICorner",tb2).CornerRadius=UDim.new(0,5)
