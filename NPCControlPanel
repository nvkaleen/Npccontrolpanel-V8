local function makeDraggable(fm,h)
    local dr=false; local dd=Vector2.new(0,0)
    track(h.InputBegan:Connect(function(i) if i.UserInputType~=Enum.UserInputType.MouseButton1 then return end; dr=true
        local m=UserInputService:GetMouseLocation(); local f=fm.AbsolutePosition; dd=Vector2.new(m.X-f.X,m.Y-f.Y) end))
    track(UserInputService.InputChanged:Connect(function(i) if not dr or i.UserInputType~=Enum.UserInputType.MouseMovement then return end
        local m=UserInputService:GetMouseLocation(); fm.Position=UDim2.new(0,m.X-dd.X,0,m.Y-dd.Y) end))
    track(UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=false end end))
