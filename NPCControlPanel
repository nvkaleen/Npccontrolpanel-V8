    local function cRow(dn,ky,ix) local rw=Instance.new("Frame"); rw.Size=UDim2.new(1,-8,0,RH); rw.Position=UDim2.new(0,4,0,4+(ix-1)*(RH+RP)); rw.BackgroundColor3=Color3.fromRGB(26,26,38); rw.BorderSizePixel=0; rw.ZIndex=82; rw.Parent=psc; Instance.new("UICorner",rw).CornerRadius=UDim.new(0,5)
