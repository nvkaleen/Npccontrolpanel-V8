-- Tab 3 Autos
local function setAS(l,k,a) states[k]=a; local b=btns3[l]; if b then b.btn.Text=a and "⏹ ON" or "OFF"; b.dot.BackgroundColor3=a and Color3.fromRGB(0,235,70) or Color3.fromRGB(65,65,65)
    if a then task.spawn(function() while states[k] do TweenService:Create(b.dot,TweenInfo.new(0.4),{BackgroundColor3=Color3.fromRGB(0,235,70)}):Play(); task.wait(0.4)
        if not states[k] then break end; TweenService:Create(b.dot,TweenInfo.new(0.4),{BackgroundColor3=Color3.fromRGB(0,135,32)}):Play(); task.wait(0.4) end
        b.dot.BackgroundColor3=Color3.fromRGB(65,65,65) end) end end end

track(btns3["Auto Fling"].btn.MouseButton1Click:Connect(function() local ns=not states.autoFling; setAS("Auto Fling","autoFling",ns)
    if ns then task.spawn(function() local ep=loopEpoch; while states.autoFling and ep==loopEpoch do
        for _,e in ipairs(allNPCRootsInRange(flingRange)) do pcall(function() e.hrp.Velocity=Vector3.new(math.random()*2-1,0.5,math.random()*2-1).Unit*flingStrength end) end; task.wait(0.5) end end) end end))

track(btns3["Bring Loop"].btn.MouseButton1Click:Connect(function() local ns=not states.bringLoop; setAS("Bring Loop","bringLoop",ns)
    if ns then task.spawn(function() local ep=loopEpoch; while states.bringLoop and ep==loopEpoch do local mH=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if mH then local npcs=allNPCRoots(); local named=buildDisplayNames(npcs); local fl={}
            for _,item in ipairs(named) do local k=getNPCKey(item.e.model); if next(bringFilter)==nil or bringFilter[k]~=false then table.insert(fl,item) end end
            for i,item in ipairs(fl) do local a=(i/math.max(1,#fl))*math.pi*2; bringNPCToPos(item.e,mH.CFrame*CFrame.new(math.cos(a)*4,0,math.sin(a)*4),item.display) end
        end; task.wait(0.01) end end) end end))

track(btns3["Ragdoll Loop"].btn.MouseButton1Click:Connect(function() local ns=not states.ragdollLoop; setAS("Ragdoll Loop","ragdollLoop",ns)
    if ns then task.spawn(function() local ep=loopEpoch; while states.ragdollLoop and ep==loopEpoch do
        for _,e in ipairs(allNPCRoots()) do pcall(function() ragdollNPC(e.model) end) end; task.wait(1) end end) end end))

-- STOP ALL
local function rAU() local ab=gAB(); for _,m in ipairs(allCM) do if ab[m.label] then ab[m.label].Text=m.label end end
    for _,d in ipairs(t1D) do if btns[d.label] then btns[d.label].Text=d.label end end
    for _,b in pairs(btns3) do b.btn.Text="OFF"; b.dot.BackgroundColor3=Color3.fromRGB(65,65,65) end
    teleportSelectedNPC=nil; followLoopActive=false; followingNPCs={} end

track(stB.MouseButton1Click:Connect(function() resetStates(); hideUV(); rAU() end))
track(anB.MouseButton1Click:Connect(function() anchorActive=not anchorActive; anB.Text="Anchor Toggle: "..(anchorActive and "ON" or "OFF"); anB.BackgroundColor3=anchorActive and Color3.fromRGB(0,110,52) or Color3.fromRGB(70,35,35) end))
track(setB.MouseButton1Click:Connect(function() sP.Visible=not sP.Visible end))
track(sPCB.MouseButton1Click:Connect(function() sP.Visible=false end))

-- ============================================================
--  CLICK HANDLER (handles all modes including new ones)
-- ============================================================
track(mouse.Button1Down:Connect(function()
    local target=mouse.Target; if not target then return end

    -- Anchor toggle
    if anchorActive and target:IsA("BasePart") then target.Anchored=not target.Anchored; return end

    -- Teleport NPC: second click = destination
    if states.teleportClick and teleportSelectedNPC then
        local destPos = mouse.Hit.Position
        pcall(function()
            local hrp = teleportSelectedNPC:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.Anchored = false
                hrp.CFrame = CFrame.new(destPos + Vector3.new(0,3,0))
                hrp.Velocity = Vector3.new(0,0,0)
            end
        end)
        teleportSelectedNPC = nil
        btns5["📍 Teleport NPC (Click)"].Text = "⏹ 📍 Teleport NPC (Click): ON"
        return
    end

    local md=target:FindFirstAncestorOfClass("Model"); if not md then return end
    local hm=md:FindFirstChildOfClass("Humanoid"); local hr=md:FindFirstChild("HumanoidRootPart")
    local isN=hm and not Players:GetPlayerFromCharacter(md); if not isN then return end

    -- Tab 1 modes
    if states.viewNPC then workspace.CurrentCamera.CameraSubject=hm; viewingNPC=true; viewedHumanoid=hm; showUV(); uvB.Text="👁 Unview: "..(md.Name or "NPC")
    elseif states.killClick then hm.Health=0
    elseif states.fling and hr then hr.Velocity=Vector3.new(math.random()*2-1,0.5,math.random()*2-1).Unit*flingStrength
    -- Tab 2 modes
    elseif states.deleteClick then pcall(function() md:Destroy() end)
    elseif states.bringClick then local mH=player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if mH and hr then bringNPCToPos({hum=hm,hrp=hr,model=md},mH.CFrame*CFrame.new(0,0,-5),md.Name) end
    elseif states.ragdollClick then ragdollNPC(md)
    -- Tab 5 (Extra) modes
    elseif states.freezeClick then
        if isNPCFrozen(md) then unfreezeNPC(md) else freezeNPC(md) end
    elseif states.teleportClick then
        teleportSelectedNPC = md
        btns5["📍 Teleport NPC (Click)"].Text = "📍 Now click destination..."
    elseif states.followMe then
        if followingNPCs[md] then
            followingNPCs[md] = nil
        else
            followingNPCs[md] = true
            startFollowLoop()
        end
    elseif states.npcSpeedClick then
        pcall(function() hm.WalkSpeed = npcSpeedValue end)
    elseif states.healthClick then
        pcall(function() hm.MaxHealth = npcHealthValue; hm.Health = npcHealthValue end)
    end
end))

