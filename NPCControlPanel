        pushRangeVisual = Instance.new("Part")
        pushRangeVisual.Shape, pushRangeVisual.Material = Enum.PartType.Ball, Enum.Material.Neon
        pushRangeVisual.Color, pushRangeVisual.Transparency = Color3.fromRGB(0, 170, 255), 0.9
        pushRangeVisual.Anchored, pushRangeVisual.CanCollide = true, false
        pushRangeVisual.Parent = workspace.CurrentCamera
