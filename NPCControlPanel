-- [[ SETTINGS SLIDERS ]]
local function createSlider(yPos, labelText, default, min, max, callback, onActive)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 60)
    frame.Position = UDim2.new(0, 10, 0, yPos)
    frame.BackgroundTransparency = 1
    frame.ZIndex = 55
    frame.Parent = settingsFrame

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 20)
    lbl.Text = labelText.." ["..default.."]"
    lbl.TextColor3 = Color3.new(0.8,0.8,0.8)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.BackgroundTransparency = 1
    lbl.ZIndex = 56
    lbl.Parent = frame

    local trackLine = Instance.new("Frame")
    trackLine.Size = UDim2.new(1, -10, 0, 6)
    trackLine.Position = UDim2.new(0, 5, 0, 30)
    trackLine.BackgroundColor3 = Color3.fromRGB(60,60,60)
    trackLine.ZIndex = 56
    trackLine.Parent = frame
    
    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new((default-min)/(max-min), -8, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    knob.Text = ""
    knob.ZIndex = 57
    knob.Parent = trackLine
    Instance.new("UICorner", knob)

    local drag = false
    local function update()
        local percent = math.clamp((UserInputService:GetMouseLocation().X - trackLine.AbsolutePosition.X) / trackLine.AbsoluteSize.X, 0, 1)
        knob.Position = UDim2.new(percent, -8, 0.5, -8)
        local val = math.floor(min + (percent * (max - min)))
        lbl.Text = labelText.." ["..val.."]"
        callback(val)
    end

    track(knob.MouseButton1Down:Connect(function() drag = true if onActive then onActive(true) end end))
    track(UserInputService.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            if drag and onActive then onActive(false) end
            drag = false 
        end 
    end))
    track(RunService.RenderStepped:Connect(function() if drag then update() end end))
end

createSlider(40, "Push Strength", 150, 1, 2500, function(v) pushStrength = v end)
createSlider(110, "Fling Strength", 300, 1, 2000, function(v) flingStrength = v end)
