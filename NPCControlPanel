local function letAllMove() local c=0; for m,d in pairs(anchoredNPCs) do pcall(function()
    if not m.Parent then return end; for _,p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then p.Anchored=false end end
    d.hum.PlatformStand=false; d.hum.WalkSpeed=d.ws or 16; d.hum.JumpPower=d.jp or 50; d.hum.JumpHeight=d.jh or 7.2
