local function updateBpCount()
    local total = 0
    local selected = 0
    for key, data in pairs(npcRows) do
        total = total + 1
        if data.enabled then selected = selected + 1 end
    end
    bpCountLabel.Text = "Selected: " .. selected .. " / " .. total
end

local function createNPCRow(npcName, npcKey, index)
    local row = Instance.new("Frame")
    row.Size              = UDim2.new(1, -10, 0, ROW_H)
    row.Position          = UDim2.new(0, 5, 0, 5 + (index - 1) * (ROW_H + ROW_PAD))
    row.BackgroundColor3  = Color3.fromRGB(28, 28, 40)
    row.BorderSizePixel   = 0
    row.ZIndex            = 82
    row.Parent            = bpScroll
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size              = UDim2.new(1, -80, 1, 0)
    nameLabel.Position          = UDim2.new(0, 10, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text              = npcName
    nameLabel.Font              = Enum.Font.Gotham
    nameLabel.TextColor3        = Color3.fromRGB(220, 220, 240)
    nameLabel.TextSize          = 12
    nameLabel.TextXAlignment    = Enum.TextXAlignment.Left
    nameLabel.TextTruncate      = Enum.TextTruncate.AtEnd
    nameLabel.ZIndex            = 83
    nameLabel.Parent            = row

    -- Default: enabled (bring this NPC)
    local enabled = true
    if bringFilter[npcKey] ~= nil then
        enabled = bringFilter[npcKey]
    end

    local toggleButton = Instance.new("TextButton")
    toggleButton.Size             = UDim2.new(0, 64, 0, 24)
    toggleButton.Position         = UDim2.new(1, -70, 0.5, -12)
    toggleButton.BackgroundColor3 = enabled and Color3.fromRGB(40, 140, 80) or Color3.fromRGB(100, 35, 35)
    toggleButton.Text             = enabled and "✓ Bring" or "✗ Skip"
    toggleButton.Font             = Enum.Font.GothamBold
    toggleButton.TextColor3       = Color3.new(1, 1, 1)
    toggleButton.TextSize         = 11
    toggleButton.ZIndex           = 84
    toggleButton.Parent           = row
    Instance.new("UICorner", toggleButton).CornerRadius = UDim.new(0, 5)

    local data = { row = row, toggleBtn = toggleButton, enabled = enabled, key = npcKey }
    npcRows[npcKey] = data

    bringFilter[npcKey] = enabled

    track(toggleButton.MouseButton1Click:Connect(function()
        data.enabled = not data.enabled
        bringFilter[data.key] = data.enabled
        if data.enabled then
            toggleButton.Text = "✓ Bring"
            toggleButton.BackgroundColor3 = Color3.fromRGB(40, 140, 80)
            TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(28, 28, 40)}):Play()
        else
            toggleButton.Text = "✗ Skip"
            toggleButton.BackgroundColor3 = Color3.fromRGB(100, 35, 35)
            TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 20, 20)}):Play()
        end
        updateBpCount()
    end))

    -- Hover effect on row
    row.MouseEnter:Connect(function()
        if data.enabled then
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(36, 36, 55)}):Play()
        else
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(45, 25, 25)}):Play()
        end
    end)
    row.MouseLeave:Connect(function()
        if data.enabled then
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(28, 28, 40)}):Play()
        else
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(35, 20, 20)}):Play()
        end
    end)

    return data
end

local function refreshNPCList()
    -- Clear existing rows
    for key, data in pairs(npcRows) do
        if data.row and data.row.Parent then
            data.row:Destroy()
        end
    end
    npcRows = {}

    local npcs = allNPCRoots()
    -- Deduplicate by model name (group same-name NPCs)
    local seen = {}
    local uniqueNPCs = {}

    for _, e in ipairs(npcs) do
        local key = getNPCKey(e.model)
        if not seen[key] then
            seen[key] = true
            table.insert(uniqueNPCs, { name = e.model.Name, key = key })
        end
    end

    -- Sort alphabetically
    table.sort(uniqueNPCs, function(a, b) return a.name:lower() < b.name:lower() end)

    for i, npc in ipairs(uniqueNPCs) do
        createNPCRow(npc.name, npc.key, i)
    end

    -- Update canvas size
    local totalH = 5 + #uniqueNPCs * (ROW_H + ROW_PAD)
    bpScroll.CanvasSize = UDim2.new(0, 0, 0, totalH)

    updateBpCount()
end

